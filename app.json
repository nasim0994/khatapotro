{
  "expo": {
    "name": "KhataPotro",
    "slug": "KhataPotro",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "khatapotro",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/favicon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundImage": "./assets/images/favicon.png",
        "monochromeImage": "./assets/images/favicon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nasim0994.KhataPotro"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-audio", "expo-asset"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c7192d2-c1ce-4617-a3ad-3c66105fffc0"
      }
    }
  }
}
